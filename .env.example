# =============================================================================
# Africa DevOps Summit — Environment Variables Reference
# =============================================================================
#
# VARIABLE RULES:
#   VITE_ prefix   = bundled into client, publicly visible
#   No VITE_ prefix = build scripts only, never reaches browser
# =============================================================================

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Africa DevOps Summit
VITE_APP_VERSION=0.0.0
# Local dev override — deployed envs use hostname detection instead
# Options: production | staging | preview | development
VITE_APP_ENV=development

# ─── ImageKit (client-safe) ───────────────────────────────────────────────────
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
VITE_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key

# ─── ImageKit (build-time only — NEVER add VITE_ prefix) ─────────────────────
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key

# ─── PostHog Analytics ────────────────────────────────────────────────────────
VITE_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_DEVTOOLS=true
VITE_DEBUG_IMAGES=false

# ─── Future — uncomment when ready ───────────────────────────────────────────
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# VITE_SENTRY_DSN=https://your_key@sentry.io/your_project