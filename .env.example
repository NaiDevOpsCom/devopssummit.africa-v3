# ImageKit Configuration
# VITE_IMAGEKIT_URL_ENDPOINT: Your ImageKit URL endpoint
# Replace 'your_imagekit_id' with your actual ImageKit ID
# Format: https://ik.imagekit.io/your_imagekit_id
# Find this value in ImageKit Dashboard → Developer Options
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# VITE_IMAGEKIT_PUBLIC_KEY: Your ImageKit public key (safe for client-side use)
# This key is public and can be safely exposed in your frontend code
# WARNING: Do NOT put your private key here; only use the public key
# Find this value in ImageKit Dashboard → Developer Options
VITE_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key

# IMAGEKIT_PRIVATE_KEY: Your ImageKit private key.
# IMPORTANT: This must NEVER be exposed to the client (no VITE_ prefix).
# It is used only by build-time scripts (e.g., scripts/fetch-gallery.ts)
# to fetch image lists from the ImageKit API.
# Obtain this from ImageKit Dashboard → Developer Options.
# CAUTION: Do NOT commit your actual private key to version control.
# Keep it in a local .env file or a secure secrets manager.
IMAGEKIT_PRIVATE_KEY=your_private_key_here
